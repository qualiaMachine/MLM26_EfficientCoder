# Copy to .env and fill in. The agent reads these at runtime (via python-dotenv).

# Any OpenAI-compatible endpoint works. Examples:
#   Ollama (default):  http://localhost:11434/v1
#   vLLM:              http://localhost:8000/v1
#   Together AI:       https://api.together.xyz/v1
LLM_BASE_URL=http://localhost:11434/v1

# Model id as the endpoint knows it (e.g. `ollama list` names for Ollama).
LLM_MODEL=qwen2.5-coder:14b # adjust to 7B if you have limited memory (< 32 GB), but expect most tests to fail with small models

# Anything non-empty for local endpoints; real key for hosted APIs.
# Use a throwaway key for the hackathon — never your personal production key.
LLM_API_KEY=ollama

# ── Provided endpoint (UW–Madison participants — default) ──────────────────────
# Shared Qwen3.6-27B-FP8 deployment hosted by ML+X; the API key comes in
# the kickoff email. Uncomment these four lines to use it — they sit below
# the Ollama values on purpose, so the later assignment wins and you don't
# have to touch the lines above. Details + etiquette: docs/uw_madison_endpoint.md
#LLM_BASE_URL=<retrieved from in-person kickoff>
#LLM_MODEL=/mnt/shared-models/qwen3.6-27B-fp8
#LLM_API_KEY=<key from the in-person kickoff>
#LLM_MAX_TOKENS=4096   # reasoning model — thinking tokens count against this; keep >= 4096

# Optional tuning
LLM_TEMPERATURE=0.0
#LLM_MAX_TOKENS=2048
#AGENT_MAX_TURNS=100
#AGENT_COMMAND_TIMEOUT_SEC=60
